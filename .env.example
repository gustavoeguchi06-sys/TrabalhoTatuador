# Copie para .env e preencha os valores.

# Obrigatória em produção (o deploy falha sem ela).
# Gere com: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=troque-por-um-valor-secreto

# True para desenvolvimento local; False (ou ausente) em produção no Railway.
DJANGO_DEBUG=True

# MySQL (opcional — sem essas variáveis usa SQLite localmente).
# No Railway use os nomes nativos MYSQLDATABASE/MYSQLUSER/etc, que também são aceitos.
MYSQL_DATABASE=
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306

# Chave VAPID para web push (conteúdo do PEM). Necessária em produção para
# as inscrições sobreviverem aos deploys; localmente é gerada automaticamente.
VAPID_PRIVATE_KEY=
