# Copie para .env e preencha os valores.

# Obrigatória em produção (o deploy falha sem ela).
# Gere com: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=troque-por-um-valor-secreto

# True para desenvolvimento local; False (ou ausente) em produção no Render.
DJANGO_DEBUG=True

# Banco de dados (opcional localmente — sem nada aqui usa SQLite).
# No Render, vincule um Postgres e a plataforma injeta DATABASE_URL sozinha.
# Exemplo: postgres://usuario:senha@host:5432/nome_do_banco
DATABASE_URL=

# Alternativa MySQL (compatibilidade). Preencha só se for usar MySQL em vez
# do Postgres. Se DATABASE_URL estiver definida, ela tem prioridade.
MYSQL_DATABASE=
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306

# Hosts extras permitidos, separados por vírgula (ex.: domínio personalizado).
# O domínio *.onrender.com é adicionado automaticamente via RENDER_EXTERNAL_HOSTNAME.
DJANGO_ALLOWED_HOSTS=

# Chave VAPID para web push (conteúdo do PEM). Necessária em produção para
# as inscrições sobreviverem aos deploys; localmente é gerada automaticamente.
VAPID_PRIVATE_KEY=
